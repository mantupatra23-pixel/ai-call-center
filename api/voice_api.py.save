import os
import requests
from fastapi import APIRouter, HTTPException, Request
from pydantic import BaseModel
from db.redis import redis_db

# --- INITIAL SETUP ---
router = APIRouter(prefix="/voice", tags=["Voice Engine"])

# Environment Variables (Render Dashboard se manage karein)
VAPI_API_KEY = os.getenv("VAPI_API_KEY")
VAPI_ASSISTANT_ID = os.getenv("VAPI_ASSISTANT_ID")
GROQ_API_KEY = os.getenv("GROQ_API_KEY")

# --- MODELS ---
class CallRequest(BaseModel):
    to_phone: str
    customer_id: str

# --- SAFE SERVICE IMPORTS ---
def safe_start_billing(call_id, customer_id):
    try:
        from services.billing_service import start_call_bill
        start_call_bill(call_id, customer_id)
    except Exception as e:
        print(f"Billing Start Error: {e}")

def safe_stop_billing(call_id, customer_id, duration):
    try:
        from services.billing_service import stop_call_billing
        stop_call_billing(call_id, customer_id, duration)
    except Exception as e:
        print(f"Billing Stop Error: {e}")

def safe_add_memory(customer_id, transcript):
    try:
        from services.ai_memory_service import add_call_memory
        add_call_memory(customer_id, transcript)
    except Exception as e:
        print(f"Memory Sync Error: {e}")

# --- CORE LOGIC (Vapi Orchestration) ---

def place_vapi_call(to_phone: str, customer_id: str):
    """
    Twilio Bypass: Vapi AI ke zariye high-speed call trigger karta hai.
    """
    url = "https://api.vapi.ai/call/phone"
    
    payload = {
        "assistantId": VAPI_ASSISTANT_ID,
        "customer": {
            "number": to_phone,
            "name": customer_id
        },
        "metadata": {
            "customer_id": customer_id
        }
    }
    
    headers = {
        "Authorization": f"Bearer {VAPI_API_KEY}",
        "Content-Type": "application/json"
    }

    try:
        response = requests.post(url, json=payload, headers=headers)
        if response.status_code == 201:
            return response.json()
        else:
            print(f"Vapi Error: {response.text}")
            return None
    except Exception as e:
        print(f"Critical Call Error: {e}")
        return None

# --- ROUTES ---

@router.post("/start")
async def start_voice_call(request: CallRequest):
    """
    Frontend Dialer Endpoint
    """
    if not VAPI_API_KEY or not VAPI_ASSISTANT_ID:
        raise HTTPException(status_code=500, detail="Vapi Config Missing")

    # Wallet Check
    balance = redis_db.get(f"wallet:{request.customer_id}")
    if balance and float(balance) <= 0:
        raise HTTPException(status_code=402, detail="Low balance in wallet")

    # Trigger Call
    result = place_vapi_call(request.to_phone, request.customer_id)
    
    if not result:
        raise HTTPException(status_code=500, detail="Call engine failed")

    call_id = result.get("id")
    
    # Internal Billing Start
    safe_start_billing(call_id, request.customer_id)
    
    return {
        "status": "success",
        "call_id": call_id,
        "message": "AI dialing..."
    }

@router.post("/webhook")
async def vapi_webhook(request: Request):
    """
    End of call report processing
    """
    try:
        data = await request.json()
        if data.get("type") == "end-of-call-report":
            call_id = data.get("id")
            customer_id = data.get("metadata", {}).get("customer_id", "unknown")
            duration = data.get("duration", 0)
            transcript = data.get("transcript", "")

            # 1. Billing
            safe_stop_billing(call_id, customer_id, duration)
            
            # 2. Memory
            safe_add_memory(customer_id, transcript)

        return {"status": "ok"}
    except Exception as e:
        return {"status": "error", "message": str(e)}

@router.get("/health")
async def health():
    return {"status": "active", "engine": "Vapi-Native"}
